# API Keys — Set the key for your preferred LLM provider.
# OpenAI is the default provider.
OPENAI_API_KEY=...
ANTHROPIC_API_KEY=...
FIREWORKS_API_KEY=...
GROQ_API_KEY=...

# Ollama runs locally — no API key needed. Just ensure Ollama is running.
# Usage: LLM_MODEL=ollama/llama3.2

# Model selection (format: provider/model-name).
# If not set, defaults to openai/gpt-5.4-nano.
LLM_MODEL=openai/gpt-5.4-nano
LLM_FAST_MODEL=openai/gpt-5.4-nano

